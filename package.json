    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "bunqueue": "^2.6.115",
    "drizzle": "^1.4.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "node-cache": "^5.1.2",
    "postgres": "^3.4.8",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  }
}
