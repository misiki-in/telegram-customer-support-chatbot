{
  "name": "search",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun --target bun build --outfile dist/server.js --production src/index.ts",
    "db:push": "drizzle-kit push",
